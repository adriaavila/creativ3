# Private web -> Eve service connection
GROWTH_AGENT_RUNTIME=eve
GROWTH_AGENT_URL=
GROWTH_AGENT_USERNAME=
GROWTH_AGENT_PASSWORD=

# --- apps/growth-agent/.env (separate deploy) ---
# DATABASE_URL=                 # same Neon DB
# GROWTH_AGENT_USERNAME=        # must match the values above
# GROWTH_AGENT_PASSWORD=
# AI_GATEWAY_API_KEY=           # Vercel AI Gateway; alternatively use Vercel OIDC
# GROWTH_MODEL=anthropic/claude-sonnet-4-6

# Social publishing and analytics (server-side only)
POSTIZ_API_URL=https://api.postiz.com
POSTIZ_API_KEY=
POSTIZ_DEFAULT_INTEGRATION=
POSTIZ_REVIEW_HOURS=48

# WAHA sidecar: WhatsApp Status/Channels, never expose the key to the browser
WAHA_URL=http://localhost:3000
WAHA_API_KEY=
WAHA_API_KEY_HASH=sha512:
WAHA_SESSION=default
WAHA_WEBHOOK_URL=
WAHA_WEBHOOK_HMAC_KEY=

# Hermes Agent gateway (migration target for the Eve growth agent)
HERMES_API_URL=http://localhost:8642
HERMES_API_KEY=
HERMES_MODEL=

# Durable weekly learning notes
BRAIN_GITHUB_TOKEN=
BRAIN_REPO=
BRAIN_DIR=growth
# Private Creativv Ops access (replaces Clerk for /ops)
OPS_ACCESS_PASSWORD=
OPS_SESSION_SECRET=
